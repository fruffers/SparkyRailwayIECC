<Page x:Class="SparkyRailwayIECC.View.SwindonRailwayPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
      xmlns:local="clr-namespace:SparkyRailwayIECC.View"
      mc:Ignorable="d" 
      d:DesignHeight="450" d:DesignWidth="800"
      Title="SwindonRailwayPage">

    <Canvas Background="Black">

        <!-- straight horizontal track -->
        <Line X1="30" Y1="100"
          X2="300" Y2="100"
          Stroke="Gray"
          StrokeThickness="4" />

        <!-- smooth diagonal / angled track -->
        <Polyline
        Points="300,100 360,100 430,180 600,180"
        Stroke="Gray"
        StrokeThickness="4"
        StrokeLineJoin="Round"
        StrokeStartLineCap="Square"
        StrokeEndLineCap="Square" />

        <Polyline
    Points="300,100 360,100 430,180"
    Stroke="Red"
    StrokeThickness="4"
    StrokeLineJoin="Round" />

        <Polyline
    Points="30,100 300,100"
    Stroke="White"
    StrokeThickness="4" />

    </Canvas>

</Page>
