<Page x:Class="SparkyRailwayIECC.Modules.View.SwindonRailwayPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
      xmlns:local="clr-namespace:SparkyRailwayIECC.Modules.View"
      mc:Ignorable="d" 
      d:DesignHeight="450" d:DesignWidth="800"
      Title="SwindonRailwayPage">

    <Canvas Background="Black">

        <!-- Orange station / platform block -->
        <Rectangle Canvas.Left="60"
                   Canvas.Top="47"
                   Width="210"
                   Height="48"
                   Fill="DarkOrange" />

        <!-- Station name -->
        <TextBlock Canvas.Left="125"
                   Canvas.Top="63"
                   Text="SWINDON"
                   Foreground="Black"
                   FontSize="16"
                   FontWeight="Medium" 
                   FontFamily="Consolas"/>

        <!-- Platform number -->
        <TextBlock Canvas.Left="68"
                   Canvas.Top="63"
                   Text="1"
                   Foreground="Black"
                   FontSize="14" 
                   FontWeight="Medium"
                   FontFamily="Consolas"/>

        <!-- First track circuit -->
        <Line X1="30" Y1="100"
              X2="294" Y2="100"
              Stroke="White"
              StrokeThickness="5"
              StrokeStartLineCap="Square"
              StrokeEndLineCap="Square" />

        <!-- Track circuit end marker / overlap rectangle -->
        <Rectangle Canvas.Left="291"
                   Canvas.Top="93"
                   Width="6"
                   Height="14"
                   Fill="White" />

        <!-- Gap between track circuits: x=297 to x=302 -->

        <!-- Next track circuit, starts after the gap -->
        <Polyline Points="302,100 360,100 430,180 600,180"
                  Stroke="Gray"
                  StrokeThickness="5"
                  StrokeLineJoin="Round"
                  StrokeStartLineCap="Square"
                  StrokeEndLineCap="Square" />

        <!-- Red occupied / selected part of track circuit -->
        <Polyline Points="302,100 360,100 430,180 600,180"
                  Stroke="Red"
                  StrokeThickness="5"
                  StrokeLineJoin="Round"
                  StrokeStartLineCap="Square"
                  StrokeEndLineCap="Square" />


        <!-- Signal bracket/post: -| shape -->
        <Line X1="565" Y1="175"
          X2="565" Y2="170"
          Stroke="Gray"
          StrokeThickness="2"
          StrokeStartLineCap="Square" />

        <Line X1="565" Y1="170"
          X2="568" Y2="170"
          Stroke="Gray"
          StrokeThickness="2"
          StrokeStartLineCap="Square"
          StrokeEndLineCap="Square" />

        <Ellipse Canvas.Left="568"
                  Canvas.Top="166.5"
                  Width="7"
                  Height="7"
                  Fill="Red" />


        <!-- Signal bracket/post: -| shape -->
        <Line X1="565" Y1="185"
          X2="565" Y2="190"
          Stroke="Gray"
          StrokeThickness="2"
          StrokeStartLineCap="Square" />

        <Line X1="562" Y1="190"
          X2="565" Y2="190"
          Stroke="Gray"
          StrokeThickness="2"
          StrokeStartLineCap="Square"
          StrokeEndLineCap="Square" Height="450" Width="800" />

        <Ellipse Canvas.Left="555"
                  Canvas.Top="186.5"
                  Width="7"
                  Height="7"
                  Fill="LawnGreen" />


    </Canvas>

</Page>